{% extends "layout.html.twig" %}

{% block title %}Mot de passe oublié - SnapFit{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Mot de passe oublié</h2>
                    <p class="text-muted text-center small mb-4">Entrez votre adresse e-mail pour recevoir un lien de réinitialisation.</p>

                    {% if error %}
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> {{ error }}
                    </div>
                    {% endif %}

                    {% if success %}
                    <div class="alert alert-success" role="alert">
                        <i class="fas fa-check-circle me-2"></i> {{ success }}
                    </div>
                    <div class="text-center mt-3">
                        <a href="index.php?controleur=utilisateur&methode=login" class="btn btn-outline-secondary">Retour à la connexion</a>
                    </div>
                    {% else %}
                    <form method="post" action="index.php?controleur=utilisateur&methode=forgotPassword">
                        <div class="mb-3">
                            <label for="email" class="form-label">Votre adresse e-mail</label>
                            <input type="email" class="form-control" id="email" name="email" placeholder="exemple@mail.com" required>
                        </div>
                        <button type="submit" class="btn btn-acheter w-100">Envoyer le lien</button>
                    </form>
                    {% endif %}
                </div>
                {% if not success %}
                <div class="card-footer bg-transparent text-center border-0">
                    <small><a href="index.php?controleur=utilisateur&methode=login" class="text-muted">Retour à la connexion</a></small>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
