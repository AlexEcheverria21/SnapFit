{% extends "layout.html.twig" %}

{% block title %}Nouveau mot de passe - SnapFit{% endblock %}

{% block content %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="text-center mb-4">Réinitialisation</h2>
                    <p class="text-muted text-center small mb-4">Choisissez un nouveau mot de passe sécurisé.</p>

                    {% if error %}
                    <div class="alert alert-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> {{ error }}
                    </div>
                    {% endif %}

                    <form method="post" action="index.php?controleur=utilisateur&methode=resetPassword">
                        <input type="hidden" name="token" value="{{ token }}">
                        
                        <div class="mb-3">
                            <label for="mdp" class="form-label">Nouveau mot de passe</label>
                            <input type="password" class="form-control" id="mdp" name="mdp" required>
                            <div class="form-text">Minimum 8 caractères, dont une majuscule et un chiffre.</div>
                        </div>

                        <div class="mb-3">
                            <label for="confirm" class="form-label">Confirmer le mot de passe</label>
                            <input type="password" class="form-control" id="confirm" name="confirm" required>
                        </div>

                        <button type="submit" class="btn btn-acheter w-100">Changer mon mot de passe</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
