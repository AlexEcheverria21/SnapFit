{% extends "layout.html.twig" %}

{% block title %}Mes Favoris - SnapFit{% endblock %}

{% block content %}
<div class="container mt-4">
    <h2 class="mb-4"><i class="fas fa-heart text-danger"></i> Mes Favoris</h2>

    {% if favoris is empty %}
        <div class="alert alert-info text-center">
            Vous n'avez aucun article en favori pour l'instant. 
            <a href="index.php?controleur=article&methode=add" class="alert-link">Lancer un scan !</a>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for article in favoris %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="position-relative" style="height: 250px; overflow: hidden;">
                        <img src="{{ article.image }}" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="{{ article.categorie }}">
                    </div>
                    <div class="card-body">
                        <h5 class="card-title">{{ article.categorie }}</h5>
                        <p class="text-muted small">Ajouté le {{ article.dateCreation|date("d/m/Y") }}</p>
                        
                        <div class="d-grid gap-2">
                            <a href="{{ article.url }}" target="_blank" class="btn btn-sm" style="background-color: #5a893a; border-color: #5a893a; color: #ffffff;">
                                <i class="fas fa-external-link-alt"></i> Voir l'offre
                            </a>
                            <div class="row g-2">
                                <div class="col-6">
                                    <a href="index.php?controleur=favori&methode=show&id={{ article.id }}" class="btn btn-outline-primary btn-sm w-100">
                                        <i class="fas fa-share-alt"></i> Partager
                                    </a>
                                </div>
                                <div class="col-6">
                                    <a href="index.php?controleur=favori&methode=delete&id={{ article.id }}" 
                                       class="btn btn-outline-danger btn-sm w-100"
                                       onclick="return confirm('Supprimer ce favori ?');">
                                        <i class="fas fa-trash"></i> Suppr.
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}