{% extends "layout.html.twig" %}

{% block title %}Administration - SnapFit{% endblock %}

{% block content %}
<div class="container-fluid mt-3">
    <div class="row g-3">
        <!-- Sidebar : Design Compact & SnapFit Green -->
        <nav class="col-md-2 d-none d-md-block">
            <div class="card border-0 shadow-sm p-2" style="background-color: #f0f7ed; min-height: 80vh;">
                <h6 class="fw-bold mb-3 px-3 pt-2 text-uppercase small" style="color: #244031; letter-spacing: 1px;">Admin Control</h6>
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <a class="nav-link admin-sidebar-link rounded-3 d-flex align-items-center {{ mode == 'users' ? 'active shadow-sm' : 'text-muted' }}" 
                           href="index.php?controleur=admin&methode=index&mode=users"
                           {% if mode == 'users' %}style="background-color: #5a893a; color: white;"{% endif %}>
                            <i class="fas fa-users me-2"></i> Utilisateurs
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link admin-sidebar-link rounded-3 d-flex align-items-center {{ mode == 'domains' ? 'active shadow-sm' : 'text-muted' }}" 
                           href="index.php?controleur=admin&methode=index&mode=domains"
                           {% if mode == 'domains' %}style="background-color: #5a893a; color: white;"{% endif %}>
                            <i class="fas fa-shield-alt me-2"></i> Anti-Scam & Éco
                        </a>
                    </li>
                </ul>
                
                <div class="mt-auto px-3 pb-3">
                    <hr class="opacity-10">
                    <a href="index.php" class="text-decoration-none small text-muted hover-green">
                        <i class="fas fa-arrow-left me-1"></i> Retour site
                    </a>
                </div>
            </div>
        </nav>

        <!-- Contenu Principal -->
        <main class="col-md-10">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h4 class="fw-bold mb-0" style="color: #244031;">
                        {% if mode == 'domains' %}Gestion des Domaines{% else %}Gestion des Utilisateurs{% endif %}
                    </h4>
                    <p class="text-muted small mb-0">Panneau de contrôle SnapFit &bull; Mode d'affichage : {{ mode|capitalize }}</p>
                </div>
                
                {% if mode == 'domains' %}
                <button class="btn btn-acheter btn-sm" data-bs-toggle="modal" data-bs-target="#addDomainModal">
                    <i class="fas fa-plus me-1"></i> Ajouter un domaine
                </button>
                {% endif %}
            </div>
            
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        {% if mode == 'users' %}
                        <!-- Tableau Utilisateurs -->
                        <table id="adminTable" class="table table-hover table-admin-compact mb-0">
                            <thead style="background-color: #244031; color: white;">
                                <tr>
                                    <th class="ps-3">ID</th>
                                    <th>Login</th>
                                    <th>Email</th>
                                    <th>Nom Complet</th>
                                    <th>Rôle</th>
                                    <th>Inscrit le</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for u in users %}
                                <tr>
                                    <td class="ps-3 text-muted">{{ u.idUtilisateur }}</td>
                                    <td><span class="fw-bold" style="color: #5a893a;">{{ u.nomConnexion }}</span></td>
                                    <td>{{ u.email }}</td>
                                    <td>{{ u.prenom }} {{ u.nom }}</td>
                                    <td>
                                        {% if u.role == 'admin' %}
                                            <span class="badge border border-danger text-danger bg-transparent" style="font-size: 0.7rem;">ADMIN</span>
                                        {% else %}
                                            <span class="badge" style="background-color: #e9f5e0; color: #5a893a; font-size: 0.7rem;">MEMBRE</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ u.dateInscription|date('d/m/Y') }}</td>
                                    <td class="text-center">
                                        <!-- Toggle Role -->
                                        <a href="index.php?controleur=admin&methode=toggle_role&id={{ u.idUtilisateur }}" 
                                           class="btn btn-sm btn-link text-muted" 
                                           title="Changer le rôle">
                                            <i class="fas fa-user-tag"></i>
                                        </a>
                                        <!-- Supprimer -->
                                        {% if u.idUtilisateur != session.user_id %}
                                        <a href="index.php?controleur=admin&methode=delete_user&id={{ u.idUtilisateur }}" 
                                           class="btn btn-sm btn-link text-danger" 
                                           onclick="return confirm('Supprimer cet utilisateur définitivement ?')"
                                           title="Supprimer">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% else %}
                        <!-- Tableau Domaines (Anti-Scam) -->
                        <table id="adminTable" class="table table-hover table-admin-compact mb-0">
                            <thead style="background-color: #244031; color: white;">
                                <tr>
                                    <th class="ps-3">ID</th>
                                    <th>Nom du Site</th>
                                    <th>URL Racine</th>
                                    <th>Statut</th>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for d in domains %}
                                <tr>
                                    <td class="ps-3 text-muted">{{ d.id }}</td>
                                    <td><span class="fw-bold" style="color: #5a893a;">{{ d.nom }}</span></td>
                                    <td><code>{{ d.urlRacine }}</code></td>
                                    <td>
                                        {% if d.statut == 'eco' %}
                                            <span class="badge bg-success" style="font-size: 0.7rem;"><i class="fas fa-leaf me-1"></i>ECO</span>
                                        {% else %}
                                            <span class="badge bg-danger" style="font-size: 0.7rem;"><i class="fas fa-exclamation-triangle me-1"></i>SCAM</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        <a href="index.php?controleur=admin&methode=delete_domain&id={{ d.id }}" class="btn btn-sm btn-link text-danger" onclick="return confirm('Supprimer ce domaine ?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        {% endif %}
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<!-- Modal Ajout Domaine -->
{% if mode == 'domains' %}
<div class="modal fade" id="addDomainModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <form action="index.php?controleur=admin&methode=add_domain" method="POST">
                <div class="modal-header" style="background-color: #244031; color: white;">
                    <h5 class="modal-title h6"><i class="fas fa-plus-circle me-2"></i>Nouveau Domaine de Confiance/Scam</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nom du site (ex: Reddit)</label>
                        <input type="text" name="nom" class="form-control" required placeholder="Nom d'affichage">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">URL Racine (ex: reddit.com)</label>
                        <input type="text" name="url" class="form-control" required placeholder="Pas de http:// ni de www.">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Type de classification</label>
                        <select name="statut" class="form-select">
                            <option value="eco">Éco-responsable (Confiance)</option>
                            <option value="scam">Scam (Alerte Risque)</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Annuler</button>
                    <button type="submit" class="btn btn-sm btn-acheter">Enregistrer</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
{% endblock %}

{% block javascripts %}
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
<script>
    $(document).ready(function () {
        $('#adminTable').DataTable({
            language: {
                url: "//cdn.datatables.net/plug-ins/1.13.4/i18n/fr-FR.json"
            },
            pageLength: 25,
            lengthMenu: [10, 25, 50, 100],
            dom: '<"p-3 d-flex justify-content-between align-items-center"lf>t<"p-3 d-flex justify-content-between align-items-center"ip>'
        });
    });
</script>
{% endblock %}
