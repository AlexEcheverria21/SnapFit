{% extends "layout.html.twig" %}

{% block title %}Bienvenue{% endblock %}

{% block content %}
<div class="hero-section">
    <div class="container">
        <div class="row align-items-center justify-content-center">
            <div class="col-lg-8 text-center">
                {% if login_success %}
                <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-check-circle me-2"></i><strong>Connexion réussie !</strong> Ravi de vous revoir.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                {% endif %}
                
                <h1 class="hero-title">Trouvez votre style <span style="color: #5a893a;">en un flash.</span></h1>
                <p class="hero-subtitle mx-auto" style="max-width: 600px;">SnapFit utilise l'intelligence artificielle pour identifier vos vêtements favoris à partir d'une simple photo et vous aider à compléter votre garde-robe.</p>
                
                <div class="d-flex gap-3 justify-content-center">
                    <a href="index.php?controleur=article&methode=add" class="btn btn-lg px-4 py-2 shadow-sm btn-acheter">
                        <i class="fas fa-camera me-2"></i>Démarrer le scan
                    </a>
                    {% if not session.user %}
                    <a href="index.php?controleur=utilisateur&methode=register" class="btn btn-lg px-4 py-2 btn-outline-secondary shadow-sm">
                        Créer un compte
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-4 my-3">
    <div class="text-center mb-4">
        <h2 class="fw-bold h4" style="color: var(--navbar-color);">Comment ça marche ?</h2>
        <p class="text-muted small">Trois étapes simples pour transformer votre façon de shopper.</p>
    </div>
    
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="row g-3">
                <!-- Feature 1 -->
                <div class="col-md-4">
                    <div class="card feature-card p-3 shadow-sm">
                        <div class="feature-icon">
                            <i class="fas fa-camera"></i>
                        </div>
                        <h3 class="mb-2">1. Scannez</h3>
                        <p class="text-muted mb-0">Prenez une photo d'un vêtement ou chargez une image pour que notre IA l'analyse instantanément.</p>
                    </div>
                </div>
                
                <!-- Feature 2 -->
                <div class="col-md-4">
                    <div class="card feature-card p-3 shadow-sm">
                        <div class="feature-icon">
                            <i class="fas fa-search"></i>
                        </div>
                        <h3 class="mb-2">2. Trouvez</h3>
                        <p class="text-muted mb-0">Accédez aux meilleures offres et aux articles similaires sur les plus grandes boutiques en ligne.</p>
                    </div>
                </div>
                
                <!-- Feature 3 -->
                <div class="col-md-4">
                    <div class="card feature-card p-3 shadow-sm">
                        <div class="feature-icon">
                            <i class="fas fa-heart"></i>
                        </div>
                        <h3 class="mb-2">3. Enregistrez</h3>
                        <p class="text-muted mb-0">Gardez vos trouvailles dans vos favoris pour les retrouver plus tard et suivre les prix.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
