{% extends "layout.html.twig" %}

{% block title %}Scanner une tenue - SnapFit{% endblock %}
{% block head %}
    <!-- Cropper.js CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">
    <style>
        .cropper-container {
            width: 100%;
            height: 450px;
            background-color: #f0f2f0;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
            margin-bottom: 25px;
        }
        
        /* Personnalisation Premium de Cropper.js */
        .cropper-view-box,
        .cropper-face {
            border-radius: 4px;
            outline: 2px solid #5a893a;
            outline-color: rgba(90, 137, 58, 0.75);
        }
        .cropper-line { background-color: #5a893a; }
        .cropper-point {
            background-color: #5a893a;
            width: 18px;
            height: 18px;
            border-radius: 50%;
        }
        .cropper-point.point-se {
            width: 18px;
            height: 18px;
            opacity: 1;
        }
        .cropper-bg {
            background-image: none !important;
            background-color: #f8f9fa !important;
        }
        
        /* Animations et Layout */
        #preview-container {
            animation: fadeIn 0.4s ease-out;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .btn-scan {
            background: linear-gradient(135deg, #5a893a 0%, #4a752e 100%);
            border: none;
            color: white;
            transition: all 0.3s ease;
        }
        .btn-scan:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(90, 137, 58, 0.3);
            color: white;
        }
        .btn-outline-custom {
            border: 2px solid #e9ecef;
            color: #6c757d;
            font-weight: 500;
        }
        .btn-outline-custom:hover {
            background-color: #f8f9fa;
            border-color: #dee2e6;
        }
    </style>
{% endblock %}

{% block content %}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            
            <h1 class="mb-4">Scanner un vêtement <i class="fas fa-search"></i></h1>
            <p class="text-muted mb-4">Glissez une photo pour identifier un vêtement et vérifier sa fiabilité.</p>

            {% if error %}
                <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i> {{ error }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endif %}

            <div class="card shadow-lg p-4">
                
                <form action="index.php?controleur=article&methode=add" method="post" enctype="multipart/form-data" id="scanForm">
                    <!-- Limite de taille pour PHP (5 Mo) -->
                    <input type="hidden" name="MAX_FILE_SIZE" value="5242880">
                
                    <div class="mb-4 text-start">
                        <label for="paysSelect" class="form-label fw-bold"><i class="fas fa-globe-europe"></i> Zone de recherche :</label>
                        <select name="pays" id="paysSelect" class="form-select shadow-sm">
                            <option value="fr" selected>France (Recommandé)</option>
                            <option value="us">États-Unis</option>
                            <option value="gb">Royaume-Uni</option>
                            <option value="es">Espagne</option>
                            <option value="de">Allemagne</option>
                            <option value="it">Italie</option>
                        </select>
                    </div>

                    <div class="drop-zone" id="drop-zone">
                        <span class="drop-zone__prompt">
                            <i class="fas fa-cloud-upload-alt fa-3x"></i><br>
                            <strong>Glissez votre photo ici</strong><br>
                            <small class="text-muted">ou cliquez pour parcourir</small><br>
                            <small class="text-secondary" style="font-size: 0.8rem;">JPG, PNG, WEBP (max. 5 Mo)</small>
                        </span>
                        
                        <input type="file" name="photo" id="photoInput" class="drop-zone__input" accept="image/*" required>
                    </div>

                    <div id="preview-container" style="display: none;">
                        <div class="d-flex align-items-center justify-content-center mb-3">
                            <span class="badge rounded-pill px-3 py-2" style="background-color: rgba(90, 137, 58, 0.1); color: #5a893a;">
                                <i class="fas fa-crop-alt me-1"></i> Optimisation de l'image
                            </span>
                        </div>
                        <h5 class="fw-bold mb-2">Cadrez votre vêtement</h5>
                        <p class="text-muted small mb-4">Ajustez la zone pour aider l'IA à identifier l'article précisément.</p>
                        
                        <div class="cropper-container">
                            <img src="" alt="Aperçu" id="image-preview">
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <button type="button" class="btn btn-outline-custom px-4" id="btnReset">
                                <i class="fas fa-undo me-2"></i> Changer de photo
                            </button>
                            <button type="submit" class="btn btn-scan px-5 py-2 fw-bold">
                                <i class="fas fa-magic me-2"></i> Lancer l'analyse
                            </button>
                        </div>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script>
document.addEventListener("DOMContentLoaded", () => {
    const dropZone = document.getElementById("drop-zone");
    const inputElement = document.getElementById("photoInput");
    const previewContainer = document.getElementById("preview-container");
    const previewImage = document.getElementById("image-preview");
    const btnReset = document.getElementById("btnReset");
    const form = document.getElementById("scanForm");
    const submitBtn = form.querySelector("button[type='submit']");
    
    let cropper = null;

    dropZone.addEventListener("click", () => inputElement.click());

    inputElement.addEventListener("change", () => {
        if (inputElement.files.length) {
            updateThumbnail(inputElement.files[0]);
        }
    });

    dropZone.addEventListener("dragover", (e) => {
        e.preventDefault();
        dropZone.classList.add("drop-zone--over");
    });

    ["dragleave", "dragend"].forEach(type => {
        dropZone.addEventListener(type, () => dropZone.classList.remove("drop-zone--over"));
    });

    dropZone.addEventListener("drop", (e) => {
        e.preventDefault();
        dropZone.classList.remove("drop-zone--over");
        if (e.dataTransfer.files.length) {
            inputElement.files = e.dataTransfer.files;
            updateThumbnail(e.dataTransfer.files[0]);
        }
    });

    function updateThumbnail(file) {
        const maxSize = 5 * 1024 * 1024;
        if (file.size > maxSize) {
            alert("L'image est trop volumineuse (maximum 5 Mo).");
            inputElement.value = "";
            return;
        }

        if (file.type.startsWith("image/")) {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => {
                previewImage.src = reader.result;
                dropZone.style.display = "none";
                previewContainer.style.display = "block";

                // Initialiser Cropper.js
                if (cropper) cropper.destroy();
                cropper = new Cropper(previewImage, {
                    viewMode: 1,
                    dragMode: 'move',
                    autoCropArea: 1,
                    restore: false,
                    guides: true,
                    center: true,
                    highlight: false,
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    toggleDragModeOnDblclick: false,
                });
            };
        } else {
            alert("Veuillez sélectionner une image valide.");
            inputElement.value = "";
        }
    }

    btnReset.addEventListener("click", () => {
        inputElement.value = "";
        dropZone.style.display = "flex";
        previewContainer.style.display = "none";
        if (cropper) {
            cropper.destroy();
            cropper = null;
        }
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fas fa-magic me-2"></i> Lancer l\'analyse';
    });

    form.addEventListener("submit", (e) => {
        e.preventDefault(); 
        
        if (!cropper) return;

        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Analyse en cours...';
        submitBtn.disabled = true;

        cropper.getCroppedCanvas({
            maxWidth: 1024,
            maxHeight: 1024,
        }).toBlob((blob) => {
            const formData = new FormData(form);
            formData.set('photo', blob, 'cropped_image.jpg');

            fetch(form.action, {
                method: 'POST',
                body: formData
            }).then(response => {
                if (response.redirected) {
                    window.location.href = response.url;
                } else {
                    return response.text().then(html => {
                        document.body.innerHTML = html;
                    });
                }
            }).catch(() => {
                alert("Erreur lors de l'envoi.");
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-magic me-2"></i> Lancer l\'analyse';
            });
        }, 'image/jpeg', 0.9);
    });
});
</script>

{% endblock %}
