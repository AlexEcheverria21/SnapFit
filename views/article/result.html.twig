{% extends "layout.html.twig" %}

{% block title %}Résultats - SnapFit{% endblock %}

{% block content %}
<div class="container mt-4">
    <!-- En-tête avec l'image scannée -->
    {% if scanImage %}
    <div class="row mb-5 align-items-center bg-light p-3 rounded">
        <div class="col-md-2 text-center">
            <img src="public/uploads/{{ scanImage }}" class="img-fluid rounded border border-3 border-white shadow-sm" style="max-height: 100px;">
        </div>
        <div class="col-md-10" id="searchHeader">
            <h3><i class="fas fa-spinner fa-spin text-primary"></i> <span id="statusTitle">Analyse en cours...</span></h3>
            <p class="mb-0 text-muted" id="statusMessage">
                SnapFit identifie les articles pour vous 
                (Zone : <strong>{{ pays|upper }}</strong>). 
                Cela peut prendre quelques secondes.
            </p>
            <div class="mt-2" id="interruptionControl">
                <button id="btnInterrupt" class="btn btn-sm btn-outline-danger">
                    <i class="fas fa-stop-circle"></i> Interrompre la recherche
                </button>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Zone d'alerte (masquée par défaut) -->
    <div id="scamAlert" class="alert alert-warning d-flex align-items-center mb-4 d-none shadow-sm" role="alert">
        <i class="fas fa-shield-alt fa-2x me-3"></i>
        <div class="flex-grow-1">
            <strong>Sécurité SnapFit activée !</strong>
            <br>
            Nous avons masqué <strong id="blockedCount">0</strong> site(s) identifiés comme frauduleux ou peu fiables.
        </div>
        <button class="btn btn-sm btn-outline-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBlockedSites" aria-expanded="false">
            <i class="fas fa-eye"></i> Voir lesquels
        </button>
    </div>

    <!-- Liste déroulante des sites bloqués -->
    <div class="collapse mb-4" id="collapseBlockedSites">
        <div class="card card-body bg-light border-warning shadow-sm">
            <h6 class="fw-bold mb-2"><i class="fas fa-ban text-danger"></i> Domaines bloqués pour votre sécurité :</h6>
            <ul id="blockedSitesList" class="list-unstyled mb-0 d-flex flex-wrap gap-2">
                <!-- Rempli par JS -->
            </ul>
            <hr>
            <p class="small text-muted mb-0">
                <i class="fas fa-info-circle"></i> Ces sites sont connus pour des pratiques peu éco-responsables ou des risques de fraudes (Scam).
            </p>
        </div>
    </div>

    <!-- Grille de résultats (Sera remplie par JS) -->
    <div class="row row-cols-1 row-cols-md-3 g-4" id="resultsGrid">
        {% for i in 1..3 %}
        <div class="col skeleton-placeholder">
            <div class="skeleton-card">
                <div class="skeleton-shimmer skeleton-img"></div>
                <div class="card-body p-0">
                    <div class="skeleton-shimmer skeleton-title"></div>
                    <div class="skeleton-shimmer skeleton-price"></div>
                    <div class="skeleton-shimmer skeleton-domain"></div>
                    <div class="skeleton-shimmer skeleton-btn"></div>
                    <div class="skeleton-shimmer skeleton-btn"></div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const resultsGrid = document.getElementById('resultsGrid');
    const scamAlert = document.getElementById('scamAlert');
    const blockedCount = document.getElementById('blockedCount');
    const statusTitle = document.getElementById('statusTitle');
    const statusMessage = document.getElementById('statusMessage');
    const btnInterrupt = document.getElementById('btnInterrupt');
    const interruptionControl = document.getElementById('interruptionControl');
    const searchHeader = document.getElementById('searchHeader');

    // AbortController pour permettre l'interruption
    const controller = new AbortController();
    const signal = controller.signal;

    // Fonction d'interruption
    btnInterrupt.addEventListener('click', () => {
        controller.abort();
        statusTitle.textContent = "Recherche interrompue";
        statusTitle.previousElementSibling.className = "fas fa-times-circle text-danger";
        statusMessage.textContent = "L'analyse a été stoppée par vos soins.";
        interruptionControl.innerHTML = '<a href="index.php?controleur=article&methode=add" class="btn btn-sm btn-acheter">Réessayer</a>';
        resultsGrid.innerHTML = '<div class="col-12 text-center py-5"><p class="text-muted">Aucun résultat affiché suite à l\'interruption.</p></div>';
    });

    // Lancement de la recherche via AJAX
    fetch('index.php?controleur=article&methode=api_results&scan={{ scanImage }}&pays={{ pays }}', { signal })
        .then(response => response.json())
        .then(data => {
            if (data.error) throw new Error(data.error);

            // Mise à jour du Header
            statusTitle.textContent = "Analyse terminée !";
            statusTitle.previousElementSibling.className = "fas fa-check-circle text-success";
            statusMessage.textContent = "Voici les articles que nous avons identifiés pour vous.";
            interruptionControl.classList.add('d-none');

            // Gestion des scams
            if (data.nbBloques > 0) {
                scamAlert.classList.remove('d-none');
                blockedCount.textContent = data.nbBloques;

                // On remplit la liste des sites bloqués
                const blockedList = document.getElementById('blockedSitesList');
                blockedList.innerHTML = '';
                data.sitesBloques.forEach(site => {
                    const li = document.createElement('li');
                    li.innerHTML = `<span class="badge bg-danger">${site}</span>`;
                    blockedList.appendChild(li);
                });
            }

            // Affichage des articles
            if (data.articles.length > 0) {
                resultsGrid.innerHTML = ''; // On vide le skeleton
                data.articles.forEach(article => {
                    const domainFull = article.url.split('//').pop().split('/')[0].replace('www.', '');
                    const domainName = domainFull.split('.').slice(0, -1).join('.').charAt(0).toUpperCase() + domainFull.split('.').slice(0, -1).join('.').slice(1);
                    
                    const ecoBadge = article.label === 'eco' ? `
                        <span class="badge bg-success position-absolute top-0 start-0 m-2">
                            <i class="fas fa-leaf"></i> Eco-responsable 
                        </span>
                    ` : '';

                    // Fonction de formatage du prix selon le pays choisi
                    const displayPrice = (function(p, curr, country) {
                        if (!p || p === 'N/C') return 'Prix N/C';
                        
                        // Nettoyage de base
                        let val = p.replace('*', '').trim();
                        let formatted = '';

                        // Si le prix contient déjà un symbole monétaire, on le renvoie tel quel
                        if (/[€$£]/.test(val)) {
                            formatted = val;
                        } else {
                            // Sinon, on applique le symbole correspondant au pays
                            const symbols = {
                                'fr': ' €', 'es': ' €', 'de': ' €', 'it': ' €',
                                'us': '$', 'gb': '£'
                            };
                            
                            const symbol = symbols[country] || ' €';

                            // Placement du symbole (avant pour $ et £, après pour €)
                            if (country === 'us' || country === 'gb') {
                                formatted = symbol + val;
                            } else {
                                formatted = val + symbol;
                            }
                        }
                        
                        return 'Env. ' + formatted;
                    })(article.prix, article.currency, '{{ pays }}');

                    const cardHtml = `
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0">
                                <div class="position-relative" style="height: 250px; overflow: hidden;">
                                    <img src="${article.image}" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="${article.titre}">
                                    ${ecoBadge}
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title text-truncate" title="${article.titre}">${article.titre}</h5>
                                    <p class="card-text fw-bold text-primary">${displayPrice}</p>
                                    <p class="card-text text-muted small"><i class="fas fa-globe"></i> ${domainName || domainFull}</p>
                                    <a href="${article.url}" target="_blank" class="btn w-100 mb-2 btn-acheter">
                                        <i class="fas fa-shopping-bag"></i> Acheter
                                    </a>
                                    {% if session.user %}
                                    <button onclick="saveFavori(this, '${encodeURIComponent(article.url)}', '${encodeURIComponent(article.image)}', '${encodeURIComponent(article.titre)}', '${encodeURIComponent(displayPrice)}')" class="btn btn-light w-100 text-danger">
                                        <i class="far fa-heart"></i> Sauvegarder
                                    </button>
                                    {% else %}
                                    <a href="index.php?controleur=utilisateur&methode=login&return_to=${encodeURIComponent(window.location.href)}" class="btn btn-light w-100 text-muted small">
                                        <i class="far fa-heart"></i> Connexion requise
                                    </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    `;
                    resultsGrid.insertAdjacentHTML('beforeend', cardHtml);
                });
            } else {
                resultsGrid.innerHTML = '<div class="col-12 text-center py-5"><p>Aucun résultat trouvé pour cette image.</p></div>';
            }
        })
        .catch(err => {
            if (err.name === 'AbortError') return; 
            console.error(err);
            statusTitle.textContent = "Erreur d'analyse";
            statusTitle.previousElementSibling.className = "fas fa-wifi text-danger";
            statusMessage.innerHTML = `<span class="text-danger fw-bold">${err.message}</span><br>Vérifiez votre connexion Internet et réessayez.`;
            resultsGrid.innerHTML = '';
            interruptionControl.innerHTML = '<a href="index.php?controleur=article&methode=add" class="btn btn-sm btn-acheter">Changer d\'image</a>';
        });
});

// Fonction AJAX pour les favoris (puisqu'on génère les boutons en JS)
function saveFavori(btn, urlEnc, imgEnc, titreEnc, prix) {
    const originalContent = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>...';

    const formData = new FormData();
    formData.append('url', decodeURIComponent(urlEnc));
    formData.append('image', decodeURIComponent(imgEnc));
    formData.append('titre', decodeURIComponent(titreEnc));
    formData.append('prix', prix);

    fetch('index.php?controleur=favori&methode=add&ajax=1', {
        method: 'POST',
        body: formData
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) {
            btn.className = "btn btn-outline-danger w-100";
            btn.innerHTML = '<i class="fas fa-heart"></i> Sauvegardé';
        } else {
            alert("Erreur");
            btn.disabled = false;
            btn.innerHTML = originalContent;
        }
    })
    .catch(() => {
        btn.disabled = false;
        btn.innerHTML = originalContent;
    });
}
</script>
{% endblock %}
