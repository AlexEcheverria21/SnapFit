{% extends "layout.html.twig" %}

{% block title %}Erreur - SnapFit{% endblock %}

{% block content %}
<div class="container mt-5 mb-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg p-5 rounded-4">
                <div class="mb-4">
                    <i class="fas fa-exclamation-triangle fa-5x text-warning"></i>
                </div>
                <h1 class="fw-bold mb-3" style="color: #244031;">Oups ! Quelque chose s'est mal passé.</h1>
                <p class="text-muted mb-4">
                    Nous rencontrons une difficulté technique temporaire. L'équipe SnapFit a été prévenue et travaille déjà à la résolution du problème.
                </p>
                
                {% if debug %}
                <div class="alert alert-light text-start border small mb-4">
                    <p class="mb-1 text-uppercase fw-bold text-muted" style="font-size: 0.7rem;">Détails techniques (Debug) :</p>
                    <code>{{ message }}</code>
                </div>
                {% endif %}

                <div class="d-grid gap-2">
                    <a href="index.php" class="btn btn-acheter py-2">
                        <i class="fas fa-home me-2"></i> Retour à l'accueil
                    </a>
                    <button onclick="window.location.reload();" class="btn btn-outline-secondary py-2">
                        <i class="fas fa-redo me-2"></i> Réessayer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
